{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/",
    "target": "ES2022",
    "module": "NodeNext",
    "inlineSourceMap": true,
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node"]
  },

  "include": ["./src"],
  "exclude": ["node_modules"]
}
